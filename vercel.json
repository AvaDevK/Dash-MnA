{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "github": {
    "silent": true
  },
  "crons": [
    {
      "path": "/api/warm",
      "schedule": "*/5 * * * *"
    }
  ],
  "functions": {
    "api/mna.js":        { "maxDuration": 60 },
    "api/warm.js":       { "maxDuration": 60 },
    "api/jira-export.js": { "maxDuration": 60 }
  }
}
